<Window x:Class="laba6._4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba6"
        mc:Ignorable="d"
        Title="_4" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label>Задание 4 (3.2 - 15)</Label>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Характеристика чисел" FontSize="18"/>
            <TextBlock Text="Напишите числа:" FontSize="16"/>

            <TextBlock Text="Число 1:" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="Num1TextBox" Width="100" FontSize="14" Margin="0,0,20,0"/>

            <TextBlock Text="Число 2:" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="Num2TextBox" Width="100" FontSize="14" Margin="0,0,20,0"/>

            <TextBlock Text="Число 3:" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="Num3TextBox" Width="100" FontSize="14"/>

            <TextBlock Text="Число 4:" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="Num4TextBox" Width="100" FontSize="14" Margin="0,0,20,0"/>

            <TextBlock Text="Число 5:" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="Num5TextBox" Width="100" FontSize="14" Margin="0,0,20,0"/>


            <Button x:Name="CheckButton" Content="Узнать характеристику" Click="Check_Double"/>

            <TextBlock Text="Характеристика:" FontSize="20"  Foreground="Red" HorizontalAlignment="Center"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>


                <Border Grid.Row="0" Grid.Column="0" BorderBrush="Black" Background="LightGray" Padding="8,5">
                    <TextBlock Text="№" HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="1"  BorderBrush="Black" Background="LightGray" Padding="8,5">
                    <TextBlock Text="Целая часть" HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" BorderBrush="Black" Background="LightGray" Padding="8,5">
                    <TextBlock Text="Дробная часть (5 знаков)" HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="3" BorderBrush="Black" Background="LightGray" Padding="8,5">
                    <TextBlock Text="Знак" HorizontalAlignment="Center"/>
                </Border>

                <!-- Строка 1 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row1Int" Grid.Row="1" Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row1Frac" Grid.Row="1" Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row1Sign" Grid.Row="1" Grid.Column="3" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>

                <!-- Строка 2 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row2Int" Grid.Row="2" Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row2Frac" Grid.Row="2" Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row2Sign" Grid.Row="2" Grid.Column="3" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>

                <!-- Строка 3 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row3Int" Grid.Row="3" Grid.Column="1"  Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row3Frac" Grid.Row="3" Grid.Column="2"  Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row3Sign" Grid.Row="3" Grid.Column="3" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>

                <!-- Строка 4 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row4Int" Grid.Row="4" Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row4Frac" Grid.Row="4" Grid.Column="2"  Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row4Sign" Grid.Row="4" Grid.Column="3" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>

                <!-- Строка 5 -->
                <TextBlock Grid.Row="5" Grid.Column="0"  Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row5Int" Grid.Row="5" Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row5Frac" Grid.Row="5" Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                <TextBlock x:Name="Row5Sign" Grid.Row="5" Grid.Column="3" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
            </Grid>
            <Button x:Name="GoToNextButton" Content="Задание 5 →" Width="120" Height="35" Background="Orange" Click="GoToNextButton_Click4"/>
        </StackPanel>
    </Grid>
</Window>
