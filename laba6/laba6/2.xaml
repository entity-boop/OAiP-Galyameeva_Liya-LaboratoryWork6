<Window x:Class="laba6._2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba6"
        mc:Ignorable="d"
        Title="_2" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Label>Задание 2 (2.2 - 4)</Label>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Поиск чисел-палиндромов" FontSize="16"/>
            <TextBlock Text="Введите число:" FontSize="14"/>

            <TextBox x:Name="Input_TextBox"/>
            <Button x:Name="Check_first_event" Content="Найти" Click="FindButton_Click"/>

            <TextBlock x:Name="ResultTextBlock" Grid.Row="2" FontSize="14"/>

            <Button x:Name="GoToNextButton" Content="Задание 3 →" Width="120" Height="35" Background="Orange" Click="GoToNextButton_Click2"/>

        </StackPanel>
    </Grid>
</Window>
