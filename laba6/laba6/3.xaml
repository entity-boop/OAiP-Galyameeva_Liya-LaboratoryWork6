<Window x:Class="laba6._3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba6"
        mc:Ignorable="d"
        Title="_3" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label>Задание 3 (3.1 - 5)</Label>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Подсчет положительных, отрицательных и нулевых элементов"  FontSize="18" />
            <TextBlock Text="Введите элементы массива через пробел:" FontSize="16"/>
            
            <TextBox x:Name="Input_TextBox"/>
            <Button x:Name="Calculate" Content="Подсчитать" Click="Calculate_Click"/>

            <TextBlock Text="Положительные" FontSize="16"  Foreground="Green" HorizontalAlignment="Center"/>
            <TextBlock x:Name="PositiveCountText" Text="0"  FontSize="24" Foreground="DarkGreen" HorizontalAlignment="Center"/>

            <TextBlock Text="Отрицательные" FontSize="16" Foreground="Red" HorizontalAlignment="Center"/>
            <TextBlock x:Name="NegativeCountText" Text="0" FontSize="24" Foreground="DarkRed" HorizontalAlignment="Center"/>

            <TextBlock Text="Нулевые" FontSize="16"  Foreground="Blue" HorizontalAlignment="Center"/>
            <TextBlock x:Name="ZeroCountText" Text="0" FontSize="24" Foreground="DarkBlue" HorizontalAlignment="Center"/>

            <Button x:Name="GoToNextButton" Content="Задание 4 →" Width="120" Height="35" Background="Orange" Click="GoToNextButton_Click3"/>
        </StackPanel>
    </Grid>
</Window>
