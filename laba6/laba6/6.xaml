<Window x:Class="laba6._6"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba6"
        mc:Ignorable="d"
        Title="_6" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label>Задание 6 (5.1 - 14)</Label>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Вычисление заработной платы." FontSize="17" Foreground="Red"/>

            <TextBlock Text="Введите оклад:" FontSize="17"/>
            <TextBox x:Name="InputSalary"/>

            <TextBlock Text="Введите количество отработанных дней:" FontSize="17"/>
            <TextBox x:Name="InputDays"/>

            <TextBlock Text="Выберите месяц:" FontSize="17"/>
            <ComboBox x:Name="MonthsComboBox" Width="200" Height="30" DisplayMemberPath="Name" >
                <ComboBoxItem Content="Январь" Tag="1"/>
                <ComboBoxItem Content="Февраль" Tag="2"/>
                <ComboBoxItem Content="Март" Tag="3"/>
                <ComboBoxItem Content="Апрель" Tag="4"/>
                <ComboBoxItem Content="Май" Tag="5"/>
                <ComboBoxItem Content="Июнь" Tag="6"/>
                <ComboBoxItem Content="Июль" Tag="7"/>
                <ComboBoxItem Content="Август" Tag="8"/>
                <ComboBoxItem Content="Сентябрь" Tag="9"/>
                <ComboBoxItem Content="Октябрь" Tag="10"/>
                <ComboBoxItem Content="Ноябрь" Tag="11"/>
                <ComboBoxItem Content="Декабрь" Tag="12"/>
            </ComboBox>

            <Button x:Name="CalculateSalary" Content="Посчитать зарплату" Click="CalculateButton"/>

            <TextBlock x:Name="FinalSalary" Padding="10"/>
        </StackPanel>
    </Grid>
</Window>